# OpenAI API Key – nur hier eintragen, niemals im Frontend!
# Kopiere diese Datei zu .env und trage deinen Schlüssel ein:
#   cp .env.example .env
#
# Schlüssel holen: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port des lokalen Servers (Standard: 3000)
PORT=3000
